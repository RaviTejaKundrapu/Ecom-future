--------------------------------------------------
-- SELLERS

create table sellers (
  id uuid primary key default uuid_generate_v4(),
  shop_name text,
  owner_name text,
  email text unique,
  phone text,
  username text unique,
  password text,
  shop_address text,
  created_at timestamp default now()
);

