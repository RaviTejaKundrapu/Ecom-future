alter table customers enable row level security;
alter table categories enable row level security;
alter table products enable row level security;
alter table product_images enable row level security;
alter table cart enable row level security;
alter table addresses enable row level security;
alter table orders enable row level security;
alter table order_items enable row level security;
alter table coupons enable row level security;
alter table coupon_customers enable row level security;
alter table coupon_products enable row level security;
alter table returns enable row level security;
alter table reviews enable row level security;
alter table wishlist enable row level security;
alter table notifications enable row level security;

-- Seller policies
create policy "seller access"
on sellers for select
using (auth.email() = email);

create policy "seller products"
on products for all
using (seller_id in (select id from sellers where email = auth.email()));

create policy "seller categories"
on categories for all
using (seller_id in (select id from sellers where email = auth.email()));

create policy "seller coupons"
on coupons for all
using (seller_id in (select id from sellers where email = auth.email()));

create policy "seller orders"
on orders for select
using (seller_id in (select id from sellers where email = auth.email()));

-- Customer policies
create policy "customer data"
on customers for all
using (auth.email() = email);

create policy "customer cart"
on cart for all
using (customer_id in (select id from customers where email = auth.email()));

create policy "customer address"
on addresses for all
using (customer_id in (select id from customers where email = auth.email()));

create policy "customer orders"
on orders for select
using (customer_id in (select id from customers where email = auth.email()));

create policy "customer wishlist"
on wishlist for all
using (customer_id in (select id from customers where email = auth.email()));


